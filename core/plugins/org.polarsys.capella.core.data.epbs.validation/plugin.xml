<plugin>
<extension
         point="org.eclipse.emf.validation.constraintProviders">
      <constraintProvider>
         <package
               namespaceUri="http://www.polarsys.org/capella/core/epbs/7.0.0">
         </package>
         <constraints
               categories="capella.category/transition/justification/epbs">
            <constraint
                  class="org.polarsys.capella.core.data.epbs.validation.configurationItem.MDCHK_ConfigurationItem_Allocation_1"
                  id="TJ_EPBS_03"
                  isEnabledByDefault="true"
                  lang="Java"
                  mode="Batch"
                  name="%constraint.name"
                  severity="WARNING"
                  statusCode="1">
               <message>
                  %constraint.message
               </message>
               <description>
                  %constraint.description
               </description>
               <target
                     class="ConfigurationItem">
               </target>
            </constraint>
            <constraint
                  class="org.polarsys.capella.core.data.epbs.validation.epbsArchitecture.MDCHK_EPBSArchitecture_EpbsArchitectureToPaRealization"
                  id="TJ_EPBS_04"
                  isEnabledByDefault="true"
                  lang="Java"
                  mode="Batch"
                  name="%constraint.name.0"
                  severity="ERROR"
                  statusCode="1">
               <message>
                  %constraint.message.0
               </message>
               <description>
                  %constraint.description.0
               </description>
               <target
                     class="EPBSArchitecture">
               </target>
            </constraint>
         </constraints>
         <constraints
               categories="capella.category/transition/consistency/components">
            <constraint
                  class="org.polarsys.capella.core.data.epbs.validation.configurationItem.MDCHK_ConfigurationItem_PhysicalComponentRealization"
                  id="TC_DC_04"
                  isEnabledByDefault="true"
                  lang="Java"
                  mode="Batch"
                  name="%constraint.name.1"
                  severity="ERROR"
                  statusCode="1">
               <message>
                  %constraint.message.1
               </message>
               <target
                     class="ConfigurationItem">
               </target>
               <description>
                  %constraint.description.1
               </description>
            </constraint>
         </constraints>
      </constraintProvider>
   </extension>
</plugin>
